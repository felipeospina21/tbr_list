{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx @biomejs/biome check --write --no-errors-on-unmatched --files-ignore-unknown=true",
            "timeout": 60,
            "statusMessage": "Running Biome check and auto-fix"
          }
        ]
      }
    ]
  }
}
