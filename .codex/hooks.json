{
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "apply_patch",
				"hooks": [
					{
						"type": "command",
						"command": "npx @biomejs/biome check --write --changed --no-errors-on-unmatched --files-ignore-unknown=true 2>&1",
						"timeout": 60,
						"statusMessage": "Running Biome check and auto-fix"
					}
				]
			}
		]
	}
}
